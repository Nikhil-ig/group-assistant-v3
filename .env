# ===== ENVIRONMENT =====
ENV=development
DEBUG=true

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=8366781443:AAHIXgGD1UXvPWw9EIDBlMk5Ktuhj2qQ8WU
TELEGRAM_BOT_USERNAME=Anynameeeeeebot

# ===== MONGODB =====
MONGODB_URI=mongodb://localhost:27018
MONGODB_DB_NAME=telegram_bot_v3

# ===== REDIS (OPTIONAL) =====
REDIS_URL=redis://localhost:6379
USE_REDIS=false

# ===== API SERVER =====
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ===== JWT & SECURITY =====
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# ===== ROLE-BASED ACCESS CONTROL (RBAC) =====
# Set your Telegram user ID as SUPERADMIN to manage all groups
# SUPERADMIN can see and control ALL groups
# GROUP_ADMIN can see and control ONLY their groups
# TODO: Replace with your actual Telegram user ID from @userinfobot
SUPERADMIN_ID=8445805523
# TODO: Replace with your actual Telegram username
SUPERADMIN_USERNAME=your_telegram_username

# ===== LOGGING =====
LOG_LEVEL=DEBUG
LOG_DIR=logs

# ===== FEATURE FLAGS =====
ENABLE_AUDIT_LOGGING=true
ENABLE_METRICS=true
ENABLE_WEB_DASHBOARD=true
ENABLE_API=true

# ===== BOT FEATURES =====
ENABLE_BAN=true
ENABLE_UNBAN=true
ENABLE_MUTE=true
ENABLE_UNMUTE=true
ENABLE_KICK=true
ENABLE_WARN=true

# ===== PAGINATION & LIMITS =====
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ===== RATE LIMITING =====
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ===== CORS SETTINGS =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ===== FRONTEND URL =====
FRONTEND_URL=http://localhost:3000
